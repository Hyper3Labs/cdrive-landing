---
import CodeBlock from './CodeBlock.astro';
---

<section id="quick-start" class="quick-start reveal">
  <div class="quick-start-inner">
    <h2>Start in 30 seconds</h2>
    <div class="steps">
      <div class="step">
        <span class="step-number">1</span>
        <div class="step-content">
          <h3>Install</h3>
          <CodeBlock lang="bash" code="npm install -g clawdrive" />
        </div>
      </div>

      <div class="step">
        <span class="step-number">2</span>
        <div class="step-content">
          <h3>Set your API key</h3>
          <CodeBlock lang="bash" code={`export GEMINI_API_KEY="your-key-here"`} />
          <p class="caption">Free at <a href="https://aistudio.google.com/apikey">aistudio.google.com/apikey</a></p>
        </div>
      </div>

      <div class="step">
        <span class="step-number">3</span>
        <div class="step-content">
          <h3>Launch</h3>
          <CodeBlock lang="bash" code="clawdrive serve --demo nasa" />
          <p class="caption">Opens the 3D file cloud with a curated NASA space dataset. Your browser will open automatically.</p>
        </div>
      </div>
    </div>

    <div class="alt-paths">
      <CodeBlock
        lang="bash"
        copyable={false}
        code={`# Run without installing:\nnpx clawdrive serve --demo nasa\n\n# Or use Docker:\ndocker run -p 7860:7860 -e GEMINI_API_KEY=your-key hyper3labs/clawdrive`}
      />
    </div>
  </div>
</section>
