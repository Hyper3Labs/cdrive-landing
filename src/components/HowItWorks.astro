<section id="how-it-works" class="how-it-works reveal">
  <div class="how-it-works-inner">
    <h2>Under the hood</h2>
    <div class="flow-diagram">

      <div class="flow-step">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/></svg>
        <div class="step-name">File</div>
        <div class="step-desc">any type</div>
      </div>

      <span class="flow-arrow">→</span>

      <div class="flow-step">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/><path d="M20 3v4"/><path d="M22 5h-4"/></svg>
        <div class="step-name">Gemini Embedding 2</div>
        <div class="step-desc">768-dim vector, shared space</div>
      </div>

      <span class="flow-arrow">→</span>

      <div class="flow-step">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5V19A9 3 0 0 0 21 19V5"/><path d="M3 12A9 3 0 0 0 21 12"/></svg>
        <div class="step-name">LanceDB</div>
        <div class="step-desc">vector DB + metadata</div>
      </div>

      <span class="flow-arrow">→</span>

      <div class="flow-step">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 3v16h16"/><path d="m5 19 6-6"/><path d="m2 6 3-3 3 3"/><path d="m18 16 3 3-3 3"/></svg>
        <div class="step-name">UMAP → 3D</div>
        <div class="step-desc">projection + coordinates</div>
      </div>

      <span class="flow-arrow">→</span>

      <div class="flow-step">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
        <div class="step-name">Your Browser</div>
        <div class="step-desc">Three.js cloud + previews</div>
      </div>

    </div>
    <div class="tech-pills">
      <span class="tech-pill">TypeScript</span>
      <span class="tech-pill">React</span>
      <span class="tech-pill">Three.js</span>
      <span class="tech-pill">LanceDB</span>
      <span class="tech-pill">Gemini</span>
      <span class="tech-pill">Express</span>
      <span class="tech-pill">UMAP</span>
    </div>
  </div>
</section>
